{
    "name": "nexa/php-skeleton",
    "description": "The NexaPHP Framework Skeleton",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "nikic/fast-route": "^1.3",
        "php-di/php-di": "^7.0",
        "doctrine/orm": "^3.1",
        "doctrine/dbal": "^4.0",
        "doctrine/migrations": "^3.7",
        "symfony/console": "^7.0",
        "symfony/cache": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Nexa\\": "core/",
            "Apps\\": "apps/"
        }
    },
    "minimum-stability": "stable"
}
